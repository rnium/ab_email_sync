# Django
SECRET_KEY=change-me-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Database – path to the directory that holds db.sqlite3
# In Docker this is set to /data (mounted volume); leave blank for local dev
DB_DIR=

# Internal URL to the api_server container (set automatically by docker-compose)
ACTUAL_API_SERVER_URL=http://api_server:3000

# Gmail Settings
EMAIL_MAX_AGE=1
EMAIL_MAX_RESULTS=1000
